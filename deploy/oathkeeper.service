[Unit]
Description=Oathkeeper Commitment Accountability Watchdog
After=network.target
Documentation=https://github.com/perttulands/oathkeeper

[Service]
Type=simple
ExecStart=/home/polis/.local/bin/oathkeeper serve
Restart=on-failure
RestartSec=5

# Logging to journald
StandardOutput=journal
StandardError=journal
SyslogIdentifier=oathkeeper

# Security hardening
NoNewPrivileges=true
PrivateTmp=true

[Install]
WantedBy=default.target
